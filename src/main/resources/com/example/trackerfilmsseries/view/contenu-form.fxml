<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.control.*?>

<GridPane xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.example.trackerfilmsseries.controller.ContenuFormController"
          hgap="10" vgap="10"
          style="-fx-padding:20;">

    <columnConstraints>
        <ColumnConstraints percentWidth="35"/>
        <ColumnConstraints percentWidth="65"/>
    </columnConstraints>

    <!-- ===== INFORMATIONS GÉNÉRALES ===== -->

    <Label text="Titre :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="txtTitre" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

    <Label text="Type :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <ComboBox fx:id="cbType" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Année :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <TextField fx:id="txtAnnee" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    <Label text="Réalisateur :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
    <TextField fx:id="txtRealisateur" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

    <Label text="Genre :" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
    <ComboBox fx:id="cbGenre" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

    <Label text="Statut :" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
    <ComboBox fx:id="cbStatut" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

    <Label text="Note :" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
    <Spinner fx:id="spNote" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

    <!-- ===== SECTION PROGRESSION (SERIE) ===== -->

    <Separator GridPane.rowIndex="7" GridPane.columnIndex="0" GridPane.columnSpan="2"/>

    <Label text="Saisons totales :" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
    <TextField fx:id="txtSaisonsTotales" GridPane.rowIndex="8" GridPane.columnIndex="1"/>

    <Label text="Saisons vues :" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
    <TextField fx:id="txtSaisonsVues" GridPane.rowIndex="9" GridPane.columnIndex="1"/>

    <Label text="Episodes totaux :" GridPane.rowIndex="10" GridPane.columnIndex="0"/>
    <TextField fx:id="txtEpisodesTotaux" GridPane.rowIndex="10" GridPane.columnIndex="1"/>

    <Label text="Episodes vus :" GridPane.rowIndex="11" GridPane.columnIndex="0"/>
    <TextField fx:id="txtEpisodesVus" GridPane.rowIndex="11" GridPane.columnIndex="1"/>

    <!-- ===== BOUTON ===== -->

    <Button text="Enregistrer"
            onAction="#handleSave"
            maxWidth="Infinity"
            GridPane.rowIndex="12"
            GridPane.columnIndex="0"
            GridPane.columnSpan="2"/>

</GridPane>